{
  "name": "@webkurier/cli-terminal",
  "version": "1.0.0",
  "description": "CLI interface for WebKurier Web Search integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webkurier": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@webkurier/websearch-core": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "enquirer": "^2.4.1",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@webkurier/eslint-config": "workspace:*",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

