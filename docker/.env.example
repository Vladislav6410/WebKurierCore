# === OpenAI Configuration ===
OPENAI_API_KEY=sk-xxxx
# Для Azure OpenAI раскомментируйте:
# AZURE_OPENAI_API_KEY=xxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1/

# === Default Search Settings ===
DEFAULT_SEARCH_MODE=fast
# allowed: fast | agentic | deep
DEFAULT_SEARCH_TIMEOUT_MS=30000
DEFAULT_LIVE_ACCESS=true

# === Domain Filtering (comma-separated, no https://) ===
# SEARCH_ALLOWED_DOMAINS=openai.com,github.com,stackoverflow.com

# === Geolocation Defaults ===
DEFAULT_LOCATION_COUNTRY=DE
DEFAULT_LOCATION_CITY=Berlin
DEFAULT_LOCATION_TIMEZONE=Europe/Berlin

# === Rate Limiting ===
SEARCH_RATE_LIMIT_PER_MINUTE=60
SEARCH_RATE_LIMIT_BURST=10

# === Observability ===
LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SENTRY_DSN=

# === Server ===
PORT=3000
NODE_ENV=production

