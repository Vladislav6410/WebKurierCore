{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebKurier TaskFlow Task",
  "type": "object",
  "required": ["flowName", "ownerAgent", "steps"],
  "properties": {
    "taskId": { "type": "string" },
    "flowName": { "type": "string" },
    "ownerAgent": { "type": "string" },
    "status": { "type": "string" },
    "context": { "type": "object" },
    "metadata": { "type": "object" },
    "steps": {
      "type": "array",
      "items": { "$ref": "./task-step.schema.json" }
    }
  }
}