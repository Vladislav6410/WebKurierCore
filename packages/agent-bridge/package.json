{
  "name": "@webkurier/agent-bridge",
  "version": "1.0.0",
  "description": "Agent bridge package for WebKurier agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./security": {
      "types": "./dist/SecurityAgent/index.d.ts",
      "default": "./dist/SecurityAgent/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@webkurier/websearch-core": "workspace:*",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}