{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@webkurier/websearch-core": ["packages/websearch-core/src/index.ts"],
      "@webkurier/websearch-core/*": ["packages/websearch-core/src/*"],
      "@webkurier/agent-bridge": ["packages/agent-bridge/src/index.ts"],
      "@webkurier/agent-bridge/*": ["packages/agent-bridge/src/*"]
    }
  }
}